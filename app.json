{
  "configVersion": "v3",
  "app": {
    "appId": 27422,
    "appName": "Daily Mandala",
    "appType": "app",
    "version": {
      "code": 1,
      "name": "1.0.0"
    },
    "icon": "icon.png",
    "vender": "zepp",
    "description": "A smartwatch app that forms part of the Daily Mandala ecosystem"
  },
  "permissions": [
    "data:os.device.info",
    "device:os.alarm",
    "device:os.local_storage",
    "device:os.network",
    "device:os.notification",
    "data:user.info"
  ],
  "runtime": {
    "apiVersion": {
      "compatible": "3.0",
      "target": "4.2",
      "minVersion": "3.0"
    }
  },
  "targets": {
    "common": {
      "module": {
        "page": {
          "pages": [
            "page/index",
            "page/collection",
            "page/help",
            "page/qr",
            "page/practice",
            "page/show",
            "page/settings"
          ]
        },
        "app-side": {
          "path": "app-side/index"
        },
        "app-service": {
          "services": [
            "app-service/delayedNewsService"
          ]
        }
      },
      "platforms": [
        {
          "st": "r",
          "dw": 480
        },
        {
          "st": "s",
          "dw": 390
        }
      ],
      "designWidth": 480
    }
  },
  "i18n": {
    "en-US": {
      "appName": "Daily Mandala"
    },
    "pt-BR": {
      "appName": "Mandala Diária"
    },
    "vi-VN": {
      "appName": "Mandala Hằng Ngày"
    },
    "id-ID": {
      "appName": "Mandala Harian"
    },
    "ru-RU": {
      "appName": "Мандала дня"
    },
    "tr-TR": {
      "appName": "Günlük Mandala"
    },
    "es-ES": {
      "appName": "Mandala Diaria"
    },
    "uk-UA": {
      "appName": "Мандала дня"
    },
    "de-DE": {
      "appName": "Tägliches Mandala"
    },
    "it-IT": {
      "appName": "Mandala del Giorno"
    },
    "zh-CN": {
      "appName": "每日曼荼罗"
    }
  },
  "defaultLanguage": "en-US"
}