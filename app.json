{
  "configVersion": "v3",
  "app": {
    "appId": 27422,
    "appName": "Daily Mandala",
    "appType": "app",
    "version": {
      "code": 1,
      "name": "1.0.1"
    },
    "icon": "icon.png",
    "vender": "zepp",
    "description": "A smartwatch app that forms part of the Daily Mandala ecosystem"
  },
  "permissions": [
    "data:os.device.info",
    "device:os.local_storage",
    "device:os.network",
    "data:user.info"
  ],
  "runtime": {
    "apiVersion": {
      "compatible": "3.0",
      "target": "4.2",
      "minVersion": "3.0"
    }
  },
  "targets": {
    "common": {
      "module": {
        "page": {
          "pages": [
            "page/index",
            "page/mandala/index",
            "page/practice/index",
            "page/help/index",
            "page/help_qr/index"
          ]
        },
        "app-side": {
          "path": "app-side/index"
        }
      },
      "platforms": [
        {
          "st": "r",
          "dw": 480
        },
        {
          "st": "s",
          "dw": 390
        }
      ],
      "designWidth": 480
    }
  },
  "i18n": {
    "en-US": {
      "appName": "Daily Mandala"
    }
  },
  "defaultLanguage": "en-US"
}
