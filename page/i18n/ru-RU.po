// general help
msgid "help_main_slide1_title"
msgstr "Ежедневная практика"

msgid "help_main_slide1_text"
msgstr "Практика открыта для всех.\n\nКаждый день появляется новая мандала по текущей дате.\n\nИспользуйте её для короткого ежедневного ритуала и ведите журнал практики."

msgid "help_main_slide2_title"
msgstr "Личная коллекция"

msgid "help_main_slide2_text"
msgstr "Коллекция показывает ваши личные мандалы как on-chain NFT.\n\nДата рождения или другая значимая дата может существовать только в одном экземпляре.\n\nКаждая мандала принадлежит только одному владельцу."

msgid "help_main_slide3_title"
msgstr "Получите свою"

msgid "help_main_slide3_text"
msgstr "Сминтите личную мандалу на сайте.\n\nПодключите кошелёк, свяжите его с часами и откройте свою коллекцию."

msgid "help_main_slide3_action"
msgstr "Сканировать для минта"

msgid "help_qr_title"
msgstr "Минт и привязка"

msgid "help_qr_intro"
msgstr "Сканируйте телефоном, чтобы открыть сайт."

msgid "help_qr_domain"
msgstr "mandala.garageno9.site"

msgid "help_qr_text"
msgstr "Сминтите мандалу, подключите кошелёк, затем свяжите эти часы."

msgid "common_back"
msgstr "Назад"

//practice help
msgid "help_practice_slide1_title"
msgstr "Daily Practice"

msgid "help_practice_slide1_text"
msgstr "Each day has its own mandala.\nOpen it. Breathe with it.\nEven 3 minutes is enough.\n\nStreak — your current\nseries of daily sessions.\nBest — your personal record."

msgid "help_practice_slide2_title"
msgstr "One date.\nOne mandala."

msgid "help_practice_slide2_text"
msgstr "Every calendar date has\nexactly one mandala.\n\nOnly one person\ncan ever own it.\n\nYour birthday.\nA day that changed your life.\nIt may still be unclaimed."

msgid "help_practice_slide3_title"
msgstr "One own."

msgid "help_practice_slide3_text"
msgstr "See your personal mandala\nand check if your date\nis still available.\n\nOnce taken —\nit is gone forever."

msgid "help_practice_slide3_action"
msgstr "Visit website →"

