msgstr "Mint & Link"

msgid "help_qr_intro"
msgstr "Scan with your phone to open the website."

msgid "help_qr_domain"
msgstr "mandala.garageno9.site"

msgid "help_qr_text"
msgstr "Mint your mandala, connect your wallet, then link this watch."

